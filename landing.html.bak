<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>溯光 — 把你的故事变成游戏</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Noto+Serif+SC:wght@300;400;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="./landing.css" />
  </head>
  <body>
    <main class="landing-shell">
      <!-- 背景图层 -->
      <div class="landing-bg" aria-hidden="true"></div>
      <div class="landing-grain" aria-hidden="true"></div>
      <div class="landing-vignette" aria-hidden="true"></div>

      <!-- 顶部导航 -->
      <nav class="landing-nav" id="landingNav" aria-label="主导航">
        <div class="nav-brand">
          <span class="nav-brand-main">溯光</span>
          <span class="nav-brand-sub">SUGUANG</span>
        </div>
        <div class="nav-links">
          <a href="#how">创作</a>
          <a href="#games">游戏广场</a>
          <a href="#about">关于</a>
          <a href="./creator.html" class="nav-cta">开始创作</a>
        </div>
      </nav>

      <!-- ══════ 英雄区 ══════ -->
      <section class="hero" aria-label="溯光平台">
        <div class="hero-content">
          <p class="hero-eyebrow">
            <span class="eyebrow-dot"></span>
            剧本 · 小说 · 视觉小说 · 互动游戏
          </p>
          <h1 class="hero-brand-title">溯光</h1>
          <p class="hero-tagline">把你的故事，变成别人的体验</p>
          <p class="hero-desc">
            上传你的剧本或小说，溯光帮你转化为可互动的视觉游戏，<br />
            发布到广场，让更多人读见你的世界。
          </p>
          <div class="hero-actions">
            <a href="./creator.html" class="btn btn--primary">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M8 2v12M2 8h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
              开始创作
            </a>
            <a href="#games" class="btn btn--ghost">
              <span>浏览游戏广场</span>
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M1 7h12M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- 右侧装饰 -->
        <div class="hero-decor" aria-hidden="true">
          <span></span><span></span><span></span>
        </div>
        <div class="hero-scroll" aria-hidden="true">
          <span>SCROLL</span>
          <div class="scroll-line"></div>
        </div>
      </section>

      <!-- ══════ 如何运作 ══════ -->
      <section class="how" id="how" aria-label="如何创作">
        <header class="section-header">
          <p class="section-kicker">How it works</p>
          <h2>三步，把文字变成可玩的故事</h2>
        </header>
        <div class="steps-grid">
          <div class="step">
            <span class="step-num">01</span>
            <h3>上传剧本</h3>
            <p>支持小说、剧本、对话稿等多种格式。溯光自动解析人物、场景和对话结构。</p>
          </div>
          <div class="step-divider" aria-hidden="true"></div>
          <div class="step">
            <span class="step-num">02</span>
            <h3>视觉化编排</h3>
            <p>选择场景画面、角色立绘与配乐，在可视化编辑器中调整故事节奏与分支选项。</p>
          </div>
          <div class="step-divider" aria-hidden="true"></div>
          <div class="step">
            <span class="step-num">03</span>
            <h3>发布 &amp; 分享</h3>
            <p>一键发布到溯光广场，私密或公开皆可。玩家的每一次选择都是你故事的延伸。</p>
          </div>
        </div>
      </section>

      <!-- ══════ 游戏广场 ══════ -->
      <section class="works" id="games" aria-label="游戏广场">
        <header class="works-header">
          <p class="section-kicker">Game Plaza</p>
          <h2>游戏广场</h2>
          <p class="section-desc">由创作者发布的互动视觉游戏，随时试玩</p>
        </header>

        <div class="works-grid">
          <!-- 主打作品：替你活到明天 -->
          <article class="work-card work-card--featured">
            <div class="work-visual">
              <div class="work-cover" style="--cover-image: url('./assets/images/cover.png')"></div>
              <div class="work-overlay"></div>
              <span class="work-badge work-badge--featured">官方示例</span>
            </div>
            <div class="work-info">
              <div class="work-meta">
                <span class="work-tag">女性向 · 悬疑</span>
                <span class="work-year">2026</span>
              </div>
              <h3 class="work-title">替你活到明天</h3>
              <p class="work-blurb">
                今晚十二点前，你必须做出选择。一封来自已故之人的短信，将四个人的命运重新编织。
                莫比乌斯环式叙事，多重结局，四条攻略路线。
              </p>
              <div class="work-creator">
                <span class="creator-dot"></span>
                <span>溯光官方 · 示例创作</span>
              </div>
              <a href="./index-v2.html" class="work-link">
                <span>进入试玩</span>
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M1 7h12M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>
          </article>

          <!-- 社区作品 -->
          <article class="work-card">
            <div class="work-visual">
              <div class="work-cover work-cover--placeholder" style="--cover-hue: 200"></div>
              <div class="work-overlay"></div>
              <span class="work-badge">创作者发布</span>
            </div>
            <div class="work-info">
              <div class="work-meta">
                <span class="work-tag">治愈 · 书信</span>
                <span class="work-year">2026</span>
              </div>
              <h3 class="work-title">第七封未寄出的信</h3>
              <p class="work-blurb">
                旧书店阁楼里，一叠写给同一个人却从未寄出的信。每一封都停在不同的年份。
              </p>
              <div class="work-creator">
                <span class="creator-dot"></span>
                <span>@林夏 · 12,400 次游玩</span>
              </div>
              <button class="work-link work-link--disabled" disabled>
                <span>即将上线</span>
              </button>
            </div>
          </article>

          <article class="work-card">
            <div class="work-visual">
              <div class="work-cover work-cover--placeholder" style="--cover-hue: 280"></div>
              <div class="work-overlay"></div>
              <span class="work-badge">创作者发布</span>
            </div>
            <div class="work-info">
              <div class="work-meta">
                <span class="work-tag">都市怪谈</span>
                <span class="work-year">2026</span>
              </div>
              <h3 class="work-title">雨夜归人</h3>
              <p class="work-blurb">
                每个雨夜，城市都会多出一些不该存在的街道。走进去的人，有的再也没回来。
              </p>
              <div class="work-creator">
                <span class="creator-dot"></span>
                <span>@暮影 · 8,200 次游玩</span>
              </div>
              <button class="work-link work-link--disabled" disabled>
                <span>即将上线</span>
              </button>
            </div>
          </article>

          <article class="work-card">
            <div class="work-visual">
              <div class="work-cover work-cover--placeholder" style="--cover-hue: 40"></div>
              <div class="work-overlay"></div>
              <span class="work-badge">创作者发布</span>
            </div>
            <div class="work-info">
              <div class="work-meta">
                <span class="work-tag">解谜 · 时间</span>
                <span class="work-year">2027</span>
              </div>
              <h3 class="work-title">镜中时钟</h3>
              <p class="work-blurb">
                古董店的镜子映出的不是现在，而是十二小时后的未来。你能否在循环中找到出口？
              </p>
              <div class="work-creator">
                <span class="creator-dot"></span>
                <span>@沉云 · 审核中</span>
              </div>
              <button class="work-link work-link--disabled" disabled>
                <span>即将上线</span>
              </button>
            </div>
          </article>
        </div>

        <div class="works-more">
          <a href="#" class="btn btn--ghost">查看全部广场游戏</a>
        </div>
      </section>

      <!-- ══════ 关于 ══════ -->
      <section class="about" id="about" aria-label="关于溯光">
        <div class="about-inner">
          <div class="about-text">
            <p class="section-kicker">About</p>
            <h2>关于溯光</h2>
            <p>
              溯光是一个面向所有人的互动叙事创作平台。
              我们相信每一个喜欢写故事的人，都值得拥有一个
              <em>把文字变成体验</em>的工具。
            </p>
            <p>
              无论是短篇小说、恋爱剧本还是悬疑推理，溯光都能帮你
              转化为视觉小说游戏——配乐、立绘、场景、分支选项，
              一应俱全。创作完成后，你可以发布到溯光广场，
              让全世界的玩家读见你的世界。
            </p>
          </div>
          <div class="about-stats">
            <div class="stat">
              <span class="stat-num">3,200+</span>
              <span class="stat-label">位创作者</span>
            </div>
            <div class="stat">
              <span class="stat-num">890+</span>
              <span class="stat-label">部作品</span>
            </div>
            <div class="stat">
              <span class="stat-num">42万+</span>
              <span class="stat-label">次游玩</span>
            </div>
          </div>
        </div>
      </section>

      <!-- ══════ CTA Banner ══════ -->
      <section class="cta-banner" aria-label="开始创作">
        <div class="cta-banner-inner">
          <p class="section-kicker">Start Creating</p>
          <h2>你的下一个故事，正在等你</h2>
          <p>现在注册，免费创作你的第一部视觉小说游戏。</p>
          <a href="#" class="btn btn--primary btn--large">免费开始 →</a>
        </div>
      </section>

      <!-- 页脚 -->
      <footer class="landing-footer">
        <div class="footer-inner">
          <div class="footer-brand-block">
            <span class="nav-brand-main" style="font-size:18px">溯光</span>
            <span class="footer-tagline">把你的故事变成游戏</span>
          </div>
          <div class="footer-links">
            <a href="#how">如何创作</a>
            <a href="#games">游戏广场</a>
            <a href="#about">关于</a>
            <a href="#">隐私政策</a>
          </div>
          <span class="footer-copy">© 2024–2026 溯光</span>
        </div>
      </footer>
    </main>

    <script>
      // Nav scroll effect
      const nav = document.getElementById('landingNav');
      window.addEventListener('scroll', () => {
        nav.classList.toggle('is-scrolled', scrollY > 60);
      });

      // Active link highlight
      const sections = document.querySelectorAll('section[id]');
      const navLinks = document.querySelectorAll('.nav-links a[href^="#"]');
      window.addEventListener('scroll', () => {
        let current = '';
        sections.forEach(s => {
          if (scrollY >= s.offsetTop - 200) current = s.getAttribute('id');
        });
        navLinks.forEach(a => {
          a.classList.toggle('is-active', a.getAttribute('href') === '#' + current);
        });
      });

      // Intersection reveal
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            observer.unobserve(e.target);
          }
        });
      }, { threshold: 0.12 });
      document.querySelectorAll('.work-card, .about-inner, .cta-banner-inner, .step').forEach(el => observer.observe(el));
    </script>
  </body>
</html>
