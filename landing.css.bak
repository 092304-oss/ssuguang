/* ══════════════════════════════════════════════════════
   溯光工作室 — Landing Page
   Design dials: VARIANCE:8 · MOTION:6 · DENSITY:4
   Palette: off-black | cold-silver | rose-blush | blue-grey
   ══════════════════════════════════════════════════════ */

:root {
  color-scheme: dark;
  --ink:          #e2deda;
  --ink-dim:      rgba(226,222,218,0.55);
  --accent:       #c9a7a1;
  --accent-bright:#dbbcb6;
  --secondary:    #8895a7;
  --cyan-tint:    rgba(140,186,188,0.92);
  --base-bg:      #07080d;
  --surface:      #0e1016;
  --surface-elev: #161820;
  --line:         rgba(226,222,218,0.12);
  --line-mid:     rgba(226,222,218,0.22);
  --shadow:       0 26px 80px rgba(0,0,0,0.52);
  --shadow-sm:    0 8px 24px rgba(0,0,0,0.32);

  font-family: "Noto Serif SC", "Songti SC", serif;
}

*, *::before, *::after { box-sizing: border-box; }

html { scroll-behavior: smooth; }

body {
  margin: 0;
  background: var(--base-bg);
  color: var(--ink);
  -webkit-font-smoothing: antialiased;
}

a { color: inherit; text-decoration: none; }
button { color: inherit; font: inherit; cursor: pointer; }

/* ══════════ LANDING SHELL ═══════ */
.landing-shell {
  position: relative;
  min-height: 100vh;
  background: var(--base-bg);
  overflow-x: hidden;
}

/* ── Background layers ── */
.landing-bg {
  position: fixed;
  inset: 0;
  z-index: 0;
  background:
    radial-gradient(ellipse at 20% 30%, rgba(95,37,49,0.18), transparent 50%),
    radial-gradient(ellipse at 80% 70%, rgba(136,149,167,0.12), transparent 50%),
    var(--base-bg);
  pointer-events: none;
}

.landing-grain {
  position: fixed;
  inset: 0;
  z-index: 1;
  opacity: 0.028;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size: 128px 128px;
  pointer-events: none;
}

.landing-vignette {
  position: fixed;
  inset: 0;
  z-index: 2;
  background:
    linear-gradient(to bottom, rgba(0,0,0,0.2), transparent 30%, transparent 70%, rgba(0,0,0,0.3)),
    radial-gradient(circle at center, transparent 50%, rgba(0,0,0,0.4));
  pointer-events: none;
}

/* ══════════ NAVIGATION ═══════ */
.landing-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px clamp(24px, 5vw, 64px);
  background: linear-gradient(to bottom, rgba(7,8,13,0.8), transparent);
  backdrop-filter: blur(12px);
  transition: background 300ms ease;
}

.landing-nav.is-scrolled {
  background: rgba(7,8,13,0.92);
  border-bottom: 1px solid var(--line);
}

.nav-brand {
  display: flex;
  align-items: baseline;
  gap: 8px;
}

.nav-brand-main {
  font-family: "Noto Serif SC", serif;
  font-size: 22px;
  font-weight: 600;
  letter-spacing: 0.06em;
  color: var(--ink);
}

.nav-brand-sub {
  font-family: "Cormorant Garamond", serif;
  font-size: 11px;
  font-weight: 400;
  letter-spacing: 0.26em;
  color: var(--accent);
  text-transform: uppercase;
}

.nav-links {
  display: flex;
  gap: 32px;
}

.nav-links a {
  position: relative;
  font-family: "Noto Serif SC", serif;
  font-size: 14px;
  color: var(--ink-dim);
  letter-spacing: 0.05em;
  transition: color 200ms ease;
  padding-bottom: 4px;
}

.nav-links a::after {
  content: "";
  position: absolute;
  bottom: 0;
  left: 0;
  width: 0;
  height: 1px;
  background: var(--accent);
  transition: width 300ms ease;
}

.nav-cta {
  padding: 8px 20px;
  border: 1px solid var(--accent);
  border-radius: 2px;
  color: var(--accent-bright) !important;
  font-size: 13px;
  letter-spacing: 0.08em;
  transition: background 250ms ease, color 250ms ease !important;
}

.nav-cta:hover {
  background: var(--accent) !important;
  color: var(--base-bg) !important;
}

.nav-cta::after { display: none !important; }

/* ══════════ BTN SYSTEM ═══════ */
.btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 13px 32px;
  border-radius: 2px;
  font-family: "Noto Serif SC", serif;
  font-size: 15px;
  letter-spacing: 0.08em;
  cursor: pointer;
  border: 1px solid transparent;
  text-decoration: none;
  transition: background 250ms ease, color 250ms ease, transform 250ms ease, border-color 250ms ease;
}

.btn:hover { transform: translateY(-2px); }

.btn--primary {
  background: var(--accent);
  color: var(--base-bg);
  border-color: var(--accent);
}

.btn--primary:hover {
  background: var(--accent-bright);
  border-color: var(--accent-bright);
}

.btn--ghost {
  background: transparent;
  color: var(--ink-dim);
  border-color: var(--line-mid);
}

.btn--ghost:hover {
  border-color: var(--accent);
  color: var(--accent-bright);
}

.btn--ghost svg { transition: transform 250ms ease; }
.btn--ghost:hover svg { transform: translateX(4px); }

.btn--large {
  padding: 16px 44px;
  font-size: 17px;
}

/* ══════════ HERO EYEBROW ═══════ */
.hero-eyebrow {
  display: flex;
  align-items: center;
  gap: 10px;
  justify-content: center;
  margin: 0 0 20px;
  font-family: "Cormorant Garamond", serif;
  font-size: 13px;
  font-style: italic;
  letter-spacing: 0.14em;
  color: var(--ink-dim);
  opacity: 0;
  transform: translateY(12px);
  animation: fade-up 0.8s cubic-bezier(0.23, 1, 0.32, 1) 0.2s both;
}

.eyebrow-dot {
  display: inline-block;
  width: 5px;
  height: 5px;
  border-radius: 999px;
  background: var(--accent);
  flex-shrink: 0;
}

/* ══════════ HERO ACTIONS ═══════ */
.hero-actions {
  display: flex;
  gap: 14px;
  justify-content: center;
  flex-wrap: wrap;
  opacity: 0;
  transform: translateY(16px);
  animation: fade-up 0.8s cubic-bezier(0.23, 1, 0.32, 1) 1.05s both;
}

/* ══════════ HOW SECTION ═══════ */
.how {
  position: relative;
  z-index: 10;
  padding: 100px clamp(24px, 5vw, 64px) 80px;
}

.section-header {
  max-width: 600px;
  margin: 0 auto 64px;
  text-align: center;
}

.section-header h2 {
  margin: 0;
  font-family: "Cormorant Garamond", "Noto Serif SC", serif;
  font-size: clamp(24px, 3.5vw, 36px);
  font-weight: 300;
  letter-spacing: 0.04em;
  line-height: 1.4;
}

.steps-grid {
  display: flex;
  max-width: 1000px;
  margin: 0 auto;
  gap: 0;
  align-items: center;
}

.step {
  flex: 1;
  text-align: center;
  padding: 40px 32px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: rgba(255,255,255,0.02);
  opacity: 0;
  transform: translateY(30px);
  transition: opacity 0.7s cubic-bezier(0.23, 1, 0.32, 1), transform 0.7s cubic-bezier(0.23, 1, 0.32, 1), border-color 300ms ease;
}

.step:nth-child(1) { transition-delay: 0s; }
.step:nth-child(3) { transition-delay: 0.15s; }
.step:nth-child(5) { transition-delay: 0.3s; }

.step.is-visible {
  opacity: 1;
  transform: translateY(0);
}

.step:hover {
  border-color: var(--line-mid);
}

.step-divider {
  width: 40px;
  height: 1px;
  background: linear-gradient(to right, var(--line), var(--line-mid), var(--line));
  flex-shrink: 0;
}

.step-num {
  display: block;
  font-family: "Cormorant Garamond", serif;
  font-size: 36px;
  font-weight: 300;
  color: var(--accent);
  margin-bottom: 16px;
  line-height: 1;
}

.step h3 {
  margin: 0 0 12px;
  font-family: "Noto Serif SC", serif;
  font-size: 16px;
  font-weight: 600;
  letter-spacing: 0.06em;
}

.step p {
  margin: 0;
  font-size: 14px;
  line-height: 1.85;
  color: var(--ink-dim);
}

/* ══════════ WORK CREATOR ═══════ */
.work-creator {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 16px;
  font-size: 13px;
  color: var(--ink-dim);
}

.creator-dot {
  display: inline-block;
  width: 6px;
  height: 6px;
  border-radius: 999px;
  background: var(--accent);
  flex-shrink: 0;
}

/* ══════════ WORKS MORE ═══════ */
.works-more {
  display: flex;
  justify-content: center;
  margin-top: 48px;
}

/* ══════════ CTA BANNER ═══════ */
.cta-banner {
  position: relative;
  z-index: 10;
  padding: 100px clamp(24px, 5vw, 64px);
  text-align: center;
  background: linear-gradient(to bottom, transparent, rgba(201,167,161,0.04), transparent);
  border-top: 1px solid var(--line);
  border-bottom: 1px solid var(--line);
}

.cta-banner-inner {
  max-width: 640px;
  margin: 0 auto;
  opacity: 0;
  transform: translateY(40px);
  transition: opacity 0.8s cubic-bezier(0.23, 1, 0.32, 1), transform 0.8s cubic-bezier(0.23, 1, 0.32, 1);
}

.cta-banner-inner.is-visible {
  opacity: 1;
  transform: translateY(0);
}

.cta-banner h2 {
  margin: 0 0 16px;
  font-family: "Cormorant Garamond", "Noto Serif SC", serif;
  font-size: clamp(28px, 4vw, 42px);
  font-weight: 300;
  letter-spacing: 0.04em;
}

.cta-banner p {
  margin: 0 0 32px;
  font-size: 15px;
  color: var(--ink-dim);
  line-height: 1.8;
}

/* ══════════ FOOTER UPDATES ═══════ */
.footer-brand-block {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.footer-tagline {
  font-size: 12px;
  color: var(--ink-dim);
  letter-spacing: 0.04em;
}

.footer-links {
  display: flex;
  gap: 24px;
  align-items: center;
}

.footer-links a {
  font-size: 13px;
  color: var(--ink-dim);
  transition: color 200ms ease;
}

.footer-links a:hover {
  color: var(--ink);
}

.nav-links a:hover::after,
.nav-links a.is-active::after {
  width: 100%;
}

/* ══════════ HERO ═══════ */
.hero {
  position: relative;
  z-index: 10;
  min-height: 100vh;
  display: grid;
  place-items: center;
  padding: 0 clamp(24px, 5vw, 64px);
  overflow: hidden;
}

.hero-content {
  position: relative;
  z-index: 2;
  text-align: center;
  max-width: 720px;
}

.hero-kicker {
  margin: 0 0 16px;
  font-family: "Cormorant Garamond", serif;
  font-size: 13px;
  font-weight: 400;
  font-style: italic;
  letter-spacing: 0.22em;
  color: var(--accent);
  text-transform: uppercase;
  opacity: 0;
  transform: translateY(16px);
  animation: fade-up 0.8s cubic-bezier(0.23, 1, 0.32, 1) 0.3s both;
}

/* Brand title — large centered 溯光 */
.hero-brand-title {
  margin: 0 0 16px;
  font-family: "Noto Serif SC", serif;
  font-size: clamp(80px, 14vw, 160px);
  font-weight: 300;
  letter-spacing: 0.18em;
  line-height: 1;
  color: var(--ink);
  opacity: 0;
  transform: translateY(20px);
  animation: fade-up 1s cubic-bezier(0.23, 1, 0.32, 1) 0.4s both;
}

.hero-tagline {
  margin: 0 0 20px;
  font-family: "Cormorant Garamond", serif;
  font-size: clamp(16px, 2vw, 22px);
  font-style: italic;
  font-weight: 300;
  letter-spacing: 0.1em;
  color: var(--accent-bright);
  opacity: 0;
  transform: translateY(14px);
  animation: fade-up 0.8s cubic-bezier(0.23, 1, 0.32, 1) 0.65s both;
}

.hero-title {
  margin: 0 0 24px;
  font-family: "Cormorant Garamond", "Noto Serif SC", serif;
  font-weight: 300;
  line-height: 1.1;
  color: var(--ink);
}

.hero-line {
  display: block;
  font-size: clamp(36px, 5vw, 64px);
  letter-spacing: 0.04em;
  opacity: 0;
  transform: translateY(24px);
  animation: fade-up 1s cubic-bezier(0.23, 1, 0.32, 1) 0.5s both;
}

.hero-line--em {
  font-style: italic;
  font-weight: 400;
  color: var(--accent-bright);
  animation-delay: 0.65s;
}

.hero-desc {
  margin: 0 0 40px;
  font-size: clamp(14px, 1.5vw, 17px);
  font-weight: 300;
  line-height: 1.9;
  color: var(--ink-dim);
  letter-spacing: 0.04em;
  opacity: 0;
  transform: translateY(16px);
  animation: fade-up 0.8s cubic-bezier(0.23, 1, 0.32, 1) 0.85s both;
}

.hero-cta {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 14px 36px;
  border: 1px solid var(--accent);
  border-radius: 2px;
  background: transparent;
  color: var(--accent-bright);
  font-family: "Noto Serif SC", serif;
  font-size: 15px;
  letter-spacing: 0.12em;
  transition: background 250ms ease, color 250ms ease, transform 250ms ease;
  opacity: 0;
  transform: translateY(16px);
  animation: fade-up 0.8s cubic-bezier(0.23, 1, 0.32, 1) 1.05s both;
}

.hero-cta:hover {
  background: var(--accent);
  color: var(--base-bg);
  transform: translateY(-2px);
}

.hero-cta svg {
  transition: transform 250ms ease;
}

.hero-cta:hover svg {
  transform: translateX(4px);
}

/* Hero decorative lines */
.hero-decor {
  position: absolute;
  right: clamp(24px, 5vw, 64px);
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  gap: 8px;
  z-index: 1;
}

.hero-decor span {
  display: block;
  width: 1px;
  height: 60px;
  background: var(--line);
  opacity: 0;
  transform: scaleY(0);
  transform-origin: top;
  animation: line-grow 0.6s ease both;
}

.hero-decor span:nth-child(1) { animation-delay: 1.2s; height: 80px; background: rgba(201,167,161,0.3); }
.hero-decor span:nth-child(2) { animation-delay: 1.4s; }
.hero-decor span:nth-child(3) { animation-delay: 1.6s; height: 40px; }

/* Scroll indicator */
.hero-scroll {
  position: absolute;
  bottom: 40px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  z-index: 2;
  opacity: 0;
  animation: fade-in 0.6s ease 1.8s both;
}

.hero-scroll span {
  font-family: "Cormorant Garamond", serif;
  font-size: 10px;
  letter-spacing: 0.2em;
  color: var(--ink-dim);
  text-transform: uppercase;
}

.scroll-line {
  width: 1px;
  height: 40px;
  background: linear-gradient(to bottom, var(--ink-dim), transparent);
  animation: scroll-bob 2s ease-in-out infinite;
}

/* ══════════ SECTIONS COMMON ═══════ */
.section-kicker {
  margin: 0 0 8px;
  font-family: "Cormorant Garamond", serif;
  font-size: 13px;
  font-weight: 400;
  font-style: italic;
  letter-spacing: 0.18em;
  color: var(--accent);
  text-transform: uppercase;
}

.section-desc {
  margin: 12px 0 0;
  font-size: 15px;
  color: var(--ink-dim);
  line-height: 1.7;
}

/* ══════════ WORKS ═══════ */
.works {
  position: relative;
  z-index: 10;
  padding: 120px clamp(24px, 5vw, 64px) 100px;
  background: linear-gradient(to bottom, transparent, var(--surface) 10%, var(--surface) 90%, transparent);
}

.works-header {
  max-width: 1200px;
  margin: 0 auto 64px;
  text-align: center;
}

.works-header h2 {
  margin: 0;
  font-family: "Cormorant Garamond", "Noto Serif SC", serif;
  font-size: clamp(32px, 5vw, 48px);
  font-weight: 300;
  letter-spacing: 0.04em;
}

.works-grid {
  display: grid;
  max-width: 1200px;
  margin: 0 auto;
  gap: 24px;
  grid-template-columns: repeat(2, 1fr);
}

/* ── Work cards ── */
.work-card {
  position: relative;
  border-radius: 12px;
  overflow: hidden;
  background: var(--surface-elev);
  border: 1px solid var(--line);
  transition: transform 400ms cubic-bezier(0.23, 1, 0.32, 1), box-shadow 400ms ease, border-color 400ms ease;
  opacity: 0;
  transform: translateY(40px);
}

.work-card.is-visible {
  opacity: 1;
  transform: translateY(0);
}

.work-card:hover {
  transform: translateY(-6px);
  box-shadow: var(--shadow);
  border-color: var(--line-mid);
}

.work-card--featured {
  grid-column: span 2;
  display: grid;
  grid-template-columns: 1.1fr 1fr;
  min-height: 380px;
}

.work-visual {
  position: relative;
  overflow: hidden;
}

.work-card--featured .work-visual {
  min-height: 380px;
}

.work-cover {
  position: absolute;
  inset: 0;
  background: var(--cover-image, none) center/cover no-repeat;
  transition: transform 600ms cubic-bezier(0.23, 1, 0.32, 1);
}

.work-card:hover .work-cover {
  transform: scale(1.04);
}

.work-cover--placeholder {
  background:
    linear-gradient(135deg, hsl(var(--cover-hue, 0), 18%, 14%), hsl(var(--cover-hue, 0), 14%, 8%));
}

.work-cover--placeholder::after {
  content: "";
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 30% 40%, hsl(var(--cover-hue, 0), 20%, 22%), transparent 60%),
    radial-gradient(circle at 70% 60%, hsl(var(--cover-hue, 0), 15%, 18%), transparent 50%);
}

.work-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(7,8,13,0.9) 0%, rgba(7,8,13,0.3) 50%, transparent 100%);
  transition: opacity 400ms ease;
}

.work-card:hover .work-overlay {
  opacity: 0.85;
}

.work-badge {
  position: absolute;
  top: 16px;
  left: 16px;
  padding: 6px 14px;
  border: 1px solid var(--line);
  border-radius: 999px;
  background: rgba(7,8,13,0.7);
  backdrop-filter: blur(10px);
  font-size: 12px;
  color: var(--ink-dim);
  letter-spacing: 0.05em;
  z-index: 2;
}

.work-badge--featured {
  border-color: var(--accent);
  color: var(--accent-bright);
  background: rgba(201,167,161,0.12);
}

.work-info {
  padding: 28px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.work-card--featured .work-info {
  padding: 36px;
}

.work-meta {
  display: flex;
  gap: 12px;
  margin-bottom: 12px;
  align-items: center;
}

.work-tag {
  font-size: 12px;
  color: var(--accent);
  letter-spacing: 0.05em;
}

.work-year {
  font-family: "Cormorant Garamond", serif;
  font-size: 13px;
  color: var(--ink-dim);
}

.work-title {
  margin: 0 0 12px;
  font-family: "Cormorant Garamond", "Noto Serif SC", serif;
  font-size: clamp(22px, 2.5vw, 32px);
  font-weight: 400;
  letter-spacing: 0.02em;
  line-height: 1.3;
}

.work-card--featured .work-title {
  font-size: clamp(28px, 3vw, 40px);
}

.work-blurb {
  margin: 0 0 24px;
  font-size: 14px;
  line-height: 1.8;
  color: var(--ink-dim);
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.work-link {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  align-self: flex-start;
  padding: 10px 24px;
  border: 1px solid var(--line);
  border-radius: 2px;
  background: transparent;
  color: var(--ink-dim);
  font-family: "Noto Serif SC", serif;
  font-size: 14px;
  letter-spacing: 0.08em;
  transition: border-color 250ms ease, color 250ms ease, background 250ms ease;
}

.work-link:hover {
  border-color: var(--accent);
  color: var(--accent-bright);
  background: rgba(201,167,161,0.06);
}

.work-link svg {
  transition: transform 250ms ease;
}

.work-link:hover svg {
  transform: translateX(3px);
}

.work-link--disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.work-link--disabled:hover {
  border-color: var(--line);
  color: var(--ink-dim);
  background: transparent;
}

/* ══════════ ABOUT ═══════ */
.about {
  position: relative;
  z-index: 10;
  padding: 100px clamp(24px, 5vw, 64px);
}

.about-inner {
  max-width: 1000px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  gap: 64px;
  align-items: center;
  opacity: 0;
  transform: translateY(40px);
  transition: opacity 0.8s cubic-bezier(0.23, 1, 0.32, 1), transform 0.8s cubic-bezier(0.23, 1, 0.32, 1);
}

.about-inner.is-visible {
  opacity: 1;
  transform: translateY(0);
}

.about-text h2 {
  margin: 0 0 24px;
  font-family: "Cormorant Garamond", "Noto Serif SC", serif;
  font-size: clamp(28px, 4vw, 40px);
  font-weight: 300;
  letter-spacing: 0.04em;
}

.about-text p {
  margin: 0 0 16px;
  font-size: 15px;
  line-height: 1.9;
  color: var(--ink-dim);
}

.about-text em {
  color: var(--accent-bright);
  font-style: italic;
}

.about-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}

.stat {
  text-align: center;
  padding: 24px;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: rgba(255,255,255,0.02);
  transition: border-color 300ms ease, background 300ms ease;
}

.stat:hover {
  border-color: var(--line-mid);
  background: rgba(255,255,255,0.04);
}

.stat-num {
  display: block;
  font-family: "Cormorant Garamond", serif;
  font-size: clamp(32px, 4vw, 48px);
  font-weight: 300;
  color: var(--accent-bright);
  line-height: 1;
  margin-bottom: 8px;
}

.stat-label {
  font-size: 13px;
  color: var(--ink-dim);
  letter-spacing: 0.05em;
}

/* ══════════ CONTACT ═══════ */
.contact {
  position: relative;
  z-index: 10;
  padding: 100px clamp(24px, 5vw, 64px);
  text-align: center;
}

.contact-inner {
  max-width: 600px;
  margin: 0 auto;
  opacity: 0;
  transform: translateY(40px);
  transition: opacity 0.8s cubic-bezier(0.23, 1, 0.32, 1), transform 0.8s cubic-bezier(0.23, 1, 0.32, 1);
}

.contact-inner.is-visible {
  opacity: 1;
  transform: translateY(0);
}

.contact h2 {
  margin: 0 0 16px;
  font-family: "Cormorant Garamond", "Noto Serif SC", serif;
  font-size: clamp(28px, 4vw, 40px);
  font-weight: 300;
  letter-spacing: 0.04em;
}

.contact-desc {
  margin: 0 0 32px;
  font-size: 15px;
  color: var(--ink-dim);
  line-height: 1.8;
}

.contact-email {
  display: inline-block;
  padding: 12px 32px;
  border: 1px solid var(--accent);
  border-radius: 2px;
  color: var(--accent-bright);
  font-family: "Cormorant Garamond", serif;
  font-size: 16px;
  letter-spacing: 0.08em;
  transition: background 250ms ease, color 250ms ease;
}

.contact-email:hover {
  background: var(--accent);
  color: var(--base-bg);
}

/* ══════════ FOOTER ═══════ */
.landing-footer {
  position: relative;
  z-index: 10;
  padding: 40px clamp(24px, 5vw, 64px);
  border-top: 1px solid var(--line);
}

.footer-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.footer-brand {
  font-family: "Cormorant Garamond", serif;
  font-size: 12px;
  letter-spacing: 0.16em;
  color: var(--ink-dim);
}

.footer-copy {
  font-family: "Cormorant Garamond", serif;
  font-size: 12px;
  color: var(--ink-dim);
  opacity: 0.6;
}

/* ══════════ ANIMATIONS ═══════ */
@keyframes fade-up {
  from { opacity: 0; transform: translateY(24px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes fade-in {
  from { opacity: 0; }
  to   { opacity: 1; }
}

@keyframes line-grow {
  from { transform: scaleY(0); opacity: 0; }
  to   { transform: scaleY(1); opacity: 1; }
}

@keyframes scroll-bob {
  0%, 100% { transform: translateY(0); opacity: 1; }
  50% { transform: translateY(8px); opacity: 0.5; }
}

/* ══════════ RESPONSIVE ═══════ */
@media (max-width: 860px) {
  .works-grid {
    grid-template-columns: 1fr;
  }

  .work-card--featured {
    grid-column: span 1;
    grid-template-columns: 1fr;
  }

  .work-card--featured .work-visual {
    min-height: 240px;
  }

  .about-inner {
    grid-template-columns: 1fr;
    gap: 40px;
  }

  .about-stats {
    grid-template-columns: repeat(3, 1fr);
  }

  .hero-decor { display: none; }

  .nav-links { gap: 16px; }
  .nav-links a { font-size: 13px; }
  .nav-cta { display: none; }

  .steps-grid {
    flex-direction: column;
    gap: 16px;
  }

  .step-divider {
    width: 1px;
    height: 24px;
    background: linear-gradient(to bottom, var(--line), var(--line-mid), var(--line));
  }
}

@media (max-width: 520px) {
  .landing-nav {
    padding: 16px 20px;
  }

  .nav-brand-en { font-size: 10px; }
  .nav-brand-zh { font-size: 13px; }

  .nav-links { gap: 16px; }
  .nav-links a { font-size: 12px; }

  .hero-title { font-size: clamp(40px, 12vw, 56px); }

  .works { padding: 80px 20px 60px; }
  .about { padding: 60px 20px; }
  .contact { padding: 60px 20px; }

  .about-stats {
    grid-template-columns: 1fr;
  }

  .footer-inner {
    flex-direction: column;
    gap: 12px;
    text-align: center;
  }

  .work-info,
  .work-card--featured .work-info {
    padding: 20px;
  }
}

@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 1ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 1ms !important;
    scroll-behavior: auto !important;
  }
}
